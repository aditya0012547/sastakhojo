# SastaKhojo v2.1 — Environment Variables
# Is file ko copy karke .env naam do: cp .env.example .env

# MongoDB
MONGO_URI=mongodb://localhost:27017/sastakhojo
PORT=3000

# ── REAL PRICE FETCHING ───────────────────────────────────────────
#
# RapidAPI Key (ek key se sab APIs kaam karti hain!)
# FREE signup: https://rapidapi.com  (Google se login kar sakte ho)
# Free plan: 200-500 requests/month — demo ke liye kaafi
#
RAPIDAPI_KEY=your_rapidapi_key_here
#
# Agar key nahi hai — app demo mode mein chalega (MongoDB data)
